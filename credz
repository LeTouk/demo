# credz_demo_files.ps1 - Démo safe : recherche XLS/Word et zip local

Add-Type -AssemblyName System.Windows.Forms

# Fenêtre d'alerte / début de démo
[System.Windows.Forms.MessageBox]::Show(
    "Demo: Recherche de fichiers Word/Excel et création d'un ZIP local.",
    "Cyber Demo",
    'OK',
    'Information'
)

# Répertoire à scanner - pour la démo, on prend Documents
$searchPath = [Environment]::GetFolderPath("MyDocuments")

# Rechercher fichiers .docx, .xlsx
$files = Get-ChildItem -Path $searchPath -Include *.docx, *.xlsx -Recurse -ErrorAction SilentlyContinue

if ($files.Count -eq 0) {
    [System.Windows.Forms.MessageBox]::Show("Aucun fichier Word ou Excel trouvé dans $searchPath.", "Cyber Demo", 'OK', 'Information')
    exit
}

# Chemin ZIP de sortie
$zipPath = Join-Path $env:TEMP "Demo_Files.zip"

# Créer un ZIP
Compress-Archive -Path $files.FullName -DestinationPath $zipPath -Force

[System.Windows.Forms.MessageBox]::Show(
    "Fichiers Word/Excel trouvés et ajoutés dans :`n$zipPath",
    "Cyber Demo",
    'OK',
    'Information'
)
