
# Force PowerShell à utiliser UTF-8 pour éviter les ? à la place des accents/symboles
chcp 65001 > $null

Write-Host "`n=== ⚠️ AWARENESS DEMO : MOTS DE PASSE WIFI SAUVEGARDÉS ⚠️ ===" -ForegroundColor Yellow

# Récupère les profils WiFi
$profiles = netsh wlan show profiles | Select-String "Profil Tous les utilisateurs" | ForEach-Object {
    ($_ -split ":")[1].Trim()
}

$results = @()

foreach ($profile in $profiles) {
    $details = netsh wlan show profile name="$profile" key=clear

    $passwordLine = $details | Select-String "Contenu de la clé"
    if ($passwordLine) {
        $password = ($passwordLine -split ":",2)[1].Trim()

        # Masque les 4 derniers caractères (ou moins si mot de passe court)
        $len = $password.Length
        if ($len -gt 4) {
            $masked = $password.Substring(0, $len - 4) + "****"
        }
        elseif ($len -gt 1) {
            $masked = "*" * $len
        }
        else {
            $masked = $password
        }
    }
    else {
        $password = "(Aucun mot de passe)"
        $masked   = $password
    }

    $results += [PSCustomObject]@{
        SSID       = $profile
        Password   = $masked
    }
}

$results | Format-Table -AutoSize

Write-Host "`n💡 Moralité : Toute personne ayant accès à votre session Windows peut extraire vos mots de passe WiFi." -ForegroundColor Cyan
Write-Host "Verrouillez votre poste, évitez d’enregistrer des mots de passe sensibles, et restez prudents.`n" -ForegroundColor Cyan
``
