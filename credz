chcp 65001 > $null

Write-Host "AWARENESS DEMO : WIFI PASSWORDS" -ForegroundColor Yellow

# --- Détection automatique FR/EN pour la ligne des profils ---
$profileRegex = "Profil Tous les utilisateurs|All User Profile"

# Récupération des profils
$profiles = netsh wlan show profiles |
    Select-String $profileRegex |
    ForEach-Object {
        ($_ -split ":", 2)[1].Trim()
    }

$results = @()

foreach ($profile in $profiles) {

    # Détails du profil + key=clear
    $details = netsh wlan show profile name="$profile" key=clear

    # --- Détection auto FR/EN de la ligne du mot de passe ---
    $passwordLine = $details | Select-String "Contenu de la clé|Key Content"

    if ($passwordLine) {
        $password = ($passwordLine -split ":",2)[1].Trim()

        # Masquage des 4 derniers caractères
        $len = $password.Length
        if ($len -gt 4) {
            $masked = $password.Substring(0, $len - 4) + "****"
        }
        elseif ($len -gt 1) {
            $masked = "*" * $len
        }
        else {
            $masked = $password
        }
    }
    else {
        $password = "No password"
        $masked   = $password
    }

    $results += [PSCustomObject]@{
        SSID     = $profile
        Password = $masked
    }
}

$results | Format-Table -AutoSize
