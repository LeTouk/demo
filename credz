chcp 65001 > $null

Write-Host "AWARENESS DEMO : WIFI PASSWORD " -ForegroundColor Yellow

$profiles = netsh wlan show profiles | Select-String "Profil Tous les utilisateurs" | ForEach-Object {
    ($_ -split ":")[1].Trim()
}

$results = @()

foreach ($profile in $profiles) {
    $details = netsh wlan show profile name="$profile" key=clear

    $passwordLine = $details | Select-String "Contenu de la clé"
    if ($passwordLine) {
        $password = ($passwordLine -split ":",2)[1].Trim()

        # Masque les 4 derniers caractères (ou moins si mot de passe court)
        $len = $password.Length
        if ($len -gt 4) {
            $masked = $password.Substring(0, $len - 4) + "****"
        }
        elseif ($len -gt 1) {
            $masked = "*" * $len
        }
        else {
            $masked = $password
        }
    }
    else {
        $password = "No password"
        $masked   = $password
    }

    $results += [PSCustomObject]@{
        SSID       = $profile
        Password   = $masked
    }
}

$results | Format-Table -AutoSize
