Add-Type -AssemblyName System.Windows.Forms

# --- Fake security alert
[System.Windows.Forms.MessageBox]::Show(
    "Unusual sign-in detected.`nPlease authenticate your Microsoft Account.",
    "Microsoft Security",
    [System.Windows.Forms.MessageBoxButtons]::OK,
    [System.Windows.Forms.MessageBoxIcon]::Warning
)

# --- Fake credential prompt (NO ACCESS TO PASSWORD)
$null = $host.UI.PromptForCredential(
    "Microsoft Account",
    "Please confirm your identity",
    "$env:USERDOMAIN\$env:USERNAME",
    $env:USERDOMAIN
)

# --- Awareness message
[System.Windows.Forms.MessageBox]::Show(
    "✅ DEMONSTRATION COMPLETE`n`nThis was a cybersecurity awareness demo.`nNever enter your password in unexpected pop-ups.",
    "Cyber Awareness",
    [System.Windows.Forms.MessageBoxButtons]::OK,
    [System.Windows.Forms.MessageBoxIcon]::Information
)
