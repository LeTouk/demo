chcp 65001 > $null

Write-Host "AWARENESS DEMO : WIFI PASSWORDS" -ForegroundColor Yellow

# --- Détection automatique FR/EN pour la ligne des profils ---
$profileRegex = "Profil Tous les utilisateurs|All User Profile"

# Récupération des profils
$profiles = netsh wlan show profiles |
    Select-String $profileRegex |
    ForEach-Object {
        ($_ -split ":", 2)[1].Trim()
    }

$results = @()

foreach ($profile in $profiles) {

    # Détails du profil + key=clear
    $details = netsh wlan show profile name="$profile" key=clear

    $password = "No password"

    # --- Parsing robuste FR/EN ---
foreach ($line in $details) {

    # Normalisation unicode (clé magique)
    $cleanLine = $line.Normalize()

    if ($cleanLine -match "Key Content|Contenu") {
        $parts = $cleanLine -split ":",2
        if ($parts.Count -eq 2) {
            $password = $parts[1].Trim()
            break
        }
    }
}

    # --- Masquage ---
    if ($password -ne "No password") {
        $len = $password.Length
        if ($len -gt 4) {
            $masked = $password.Substring(0, $len - 4) + "****"
        }
        elseif ($len -gt 1) {
            $masked = "*" * $len
        }
        else {
            $masked = $password
        }
    }
    else {
        $masked = $password
    }

    $results += [PSCustomObject]@{
        SSID     = $profile
        Password = $masked
    }
}

# --- Affichage console ---
$results | Format-Table -AutoSize

# --- Export TXT fiable ---
$results | Out-File "wifi_passwords.txt" -Width 300 -Encoding utf8

